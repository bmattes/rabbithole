{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "setupFilesAfterFramework": [
      "./jest.setup.after.js"
    ],
    "moduleNameMapper": {
      "expo/src/winter$": "<rootDir>/__mocks__/expoWinter.js",
      "expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/ImportMetaRegistry.js",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^react-native-worklets-core$": "<rootDir>/__mocks__/react-native-worklets.js",
      "^react-native/Libraries/BatchedBridge/NativeModules$": "<rootDir>/__mocks__/NativeModules.js",
      "^react-native/Libraries/Animated/Animated$": "<rootDir>/__mocks__/react-native-animated.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-worklets))"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.21.2",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets-core": "^1.3.3",
    "react-test-renderer": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.1.2",
    "babel-jest": "^29.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
