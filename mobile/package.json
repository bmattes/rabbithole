{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "expo/src/winter$": "<rootDir>/__mocks__/expoWinter.js",
      "expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/ImportMetaRegistry.js",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^react-native-worklets-core$": "<rootDir>/__mocks__/react-native-worklets.js",
      "^react-native/Libraries/BatchedBridge/NativeModules$": "<rootDir>/__mocks__/NativeModules.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-worklets))"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~54.0.0",
    "expo-asset": "~10.0.10",
    "expo-constants": "~17.0.3",
    "expo-font": "~13.0.3",
    "expo-haptics": "~14.0.1",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.21.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.8.0",
    "react-native-worklets-core": "^1.3.3",
    "react-test-renderer": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "~18.3.12",
    "babel-jest": "^29.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
