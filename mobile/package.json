{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "expo/src/winter$": "<rootDir>/__mocks__/expoWinter.js",
      "expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/ImportMetaRegistry.js",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^react-native-worklets$": "<rootDir>/__mocks__/react-native-worklets.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-worklets))"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~55.0.5",
    "expo-asset": "^55.0.8",
    "expo-constants": "^55.0.7",
    "expo-font": "^55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linking": "^55.0.7",
    "expo-router": "~55.0.4",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.11.2",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "babel-jest": "^29.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
