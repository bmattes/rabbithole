{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "setupFiles": ["./jest.setup.js"],
    "moduleNameMapper": {
      "expo/src/winter$": "<rootDir>/__mocks__/expoWinter.js",
      "expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/ImportMetaRegistry.js",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^react-native-worklets$": "<rootDir>/__mocks__/react-native-worklets.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|react-native-worklets))"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~55.0.5",
    "expo-haptics": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-worklets": "^0.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "babel-jest": "^29.0.0",
    "jest": "^30.2.0",
    "jest-expo": "~55.0.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
